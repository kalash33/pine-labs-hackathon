generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Transaction {
  id              String   @id @default(cuid())
  amount          Int
  paymentMethod   String
  status          String   // SUCCESS, FAILED
  failureReason   String?
  aiRecovered     Boolean  @default(false)
  createdAt       DateTime @default(now())
}
